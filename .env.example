# Database
DATABASE_URL=postgresql://frog:frog_dev_password@localhost:5432/frog_cloud

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Clerk middleware request origin allowlist.
# Local defaults are already built into the app, but deployed hosts should be listed here.
# Replit workspace previews also auto-allow https://$REPLIT_DEV_DOMAIN when present.
CLERK_AUTHORIZED_PARTIES=http://localhost:3001,http://localhost:3002

# Screaming Frog
SF_CLI_PATH=/Applications/Screaming Frog SEO Spider.app/Contents/MacOS/ScreamingFrogSEOSpiderLauncher
JAVA_HOME=/Applications/Screaming Frog SEO Spider.app/Contents/jre

# API
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Include every browser origin that should call the API.
# Local defaults:
# - http://localhost:3001
# - http://localhost:3002
# Hosted example:
# - https://your-app.replit.app
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# Executor backend: local | none | gce
EXECUTOR_BACKEND=local

# GCP (Phase 4+)
# GCP_PROJECT_ID=
# GCS_BUCKET=
# CLOUD_SQL_INSTANCE=
