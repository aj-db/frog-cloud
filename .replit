modules = ["nodejs-20"]
entrypoint = "web/package.json"

onBoot = "cd web && if [ ! -d node_modules ]; then npm ci; fi"
run = "cd web && npm run dev:replit"

[deployment]
build = "cd web && npm ci && npm run test && npm run lint && npx tsc --noEmit && npm run build"
run = "cd web && npm run start:replit"

[gitHubImport]
requiredFiles = [".replit"]
